#!/bin/sh
# Blocks plain commits on `main` in this repo (and any worktree, since
# core.hooksPath is shared) unless one of the allowlisted escapes applies.
#
# Why: subagents dispatched into an isolated worktree have repeatedly ended up
# running `git commit` in the shared main checkout instead — landing stray
# commits directly on `main` that other concurrent sessions build on. See
# eTape CLAUDE.md "Workflow conventions" and memory `subagent-worktree-verification`.
#
# Escapes (checked in order, first match wins):
#   1. not on `main`                          -> allow (worktree branches, etc.)
#   2. ETAPE_ALLOW_MAIN_COMMIT=1 set inline    -> allow (deliberate main commit)
#   3. a merge is in progress (MERGE_HEAD)     -> allow (finishing-a-branch flow)
#   4. message starts with docs(specs): or
#      docs(plans):                            -> allow (CLAUDE.md auto-commits)
#   otherwise -> block.

branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
[ "$branch" != "main" ] && exit 0

[ "$ETAPE_ALLOW_MAIN_COMMIT" = "1" ] && exit 0

git_dir=$(git rev-parse --git-dir 2>/dev/null)
[ -n "$git_dir" ] && [ -f "$git_dir/MERGE_HEAD" ] && exit 0

first_line=$(head -n1 "$1")
case "$first_line" in
  "docs(specs):"*|"docs(plans):"*)
    exit 0
    ;;
esac

echo "" >&2
echo "BLOCKED: refusing to commit directly on 'main'." >&2
echo "" >&2
echo "If you are a subagent, you are almost certainly in the WRONG directory —" >&2
echo "cd into your assigned worktree and commit there instead." >&2
echo "" >&2
echo "If this really is a deliberate commit on main, re-run with:" >&2
echo "  ETAPE_ALLOW_MAIN_COMMIT=1 git commit ..." >&2
echo "" >&2
exit 1
